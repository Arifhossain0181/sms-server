model LeaveBalance {
  id           String    @id @default(uuid())
  staffId      String
  staff        Staff     @relation(fields: [staffId], references: [id])
  leaveType    LeaveType
  totalDays    Int
  usedDays     Int       @default(0)
  year         Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([staffId, leaveType, year])
  @@index([staffId, year])
  @@map("leave_balances")
}
