# ═══════════════════════════════════════════════════════════════════════════════
# SMS BACKEND ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════════

# DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/sms_db"

# PORT
PORT=5000

# JWT SECRET KEYS
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-long-!!!!"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars-long-!!!!"

# FRONTEND URL (for email links and redirects)
FRONTEND_URL="http://localhost:3000"

# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL CONFIGURATION (MAIL SERVICE)
# ═══════════════════════════════════════════════════════════════════════════════

# Gmail SMTP
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER="your-email@gmail.com"
MAIL_PASSWORD="your-app-specific-password"
MAIL_FROM="noreply@schoolsms.local"

# Alternative: If using other email service
# MAIL_HOST="smtp.provider.com"
# MAIL_PORT=587
# MAIL_USER="your-email@provider.com"
# MAIL_PASSWORD="your-password"

# ═══════════════════════════════════════════════════════════════════════════════
# STRIPE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_CURRENCY="usd"

# ═══════════════════════════════════════════════════════════════════════════════
# CLOUDINARY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ═══════════════════════════════════════════════════════════════════════════════
# SMTP CONFIGURATION (Legacy - if using old auth module)
# ═══════════════════════════════════════════════════════════════════════════════

SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@school.local"

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES ON EMAIL SETUP
# ═══════════════════════════════════════════════════════════════════════════════
# 
# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Generate an App Password: https://myaccount.google.com/apppasswords
# 3. Use that 16-character password as MAIL_PASSWORD
# 4. Set MAIL_USER to your full Gmail address
#
# For other providers, consult their SMTP documentation
# The mail service will automatically send welcome emails with credentials
# when an admission is approved by admin
#
